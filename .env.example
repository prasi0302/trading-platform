# Market Data Service
TICK_INTERVAL_MS=1000
REDIS_URL=redis://localhost:6379
DYNAMODB_TABLE=market-data-ticks
S3_BUCKET=trading-app-historical
AWS_REGION=us-east-1
LOG_LEVEL=INFO

# Service Ports
MARKET_DATA_PORT=8001
ORDER_SERVICE_PORT=8002
PORTFOLIO_SERVICE_PORT=8003
ALERT_SERVICE_PORT=8004
WS_GATEWAY_PORT=8005
API_GATEWAY_PORT=8000

# AWS (local development uses localstack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566
