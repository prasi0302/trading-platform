# =============================================================================
# AWS DevOps Agent Workshop - Configuration
# =============================================================================
# Copy this file to config.env and fill in your values after deploying the CDK stack.
#
# Usage: cp config.env.example config.env
#        Then fill in all values below.
# =============================================================================

# --- AWS Account ---
AWS_ACCOUNT_ID="YOUR_ACCOUNT_ID"
AWS_REGION="us-east-1"
AWS_PROFILE="default"

# --- ECR Registry ---
ECR_REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"

# --- ECS (from CDK outputs after `cdk deploy`) ---
ECS_CLUSTER="PASTE_FROM_CDK_OUTPUT"
MARKET_DATA_SERVICE="PASTE_FROM_CDK_OUTPUT"
ORDER_SERVICE="PASTE_FROM_CDK_OUTPUT"
PORTFOLIO_SERVICE="PASTE_FROM_CDK_OUTPUT"
ALERT_SERVICE="PASTE_FROM_CDK_OUTPUT"
WS_GATEWAY_SERVICE="PASTE_FROM_CDK_OUTPUT"

# --- Networking (from CDK outputs) ---
ALB_DNS="PASTE_FROM_CDK_OUTPUT"
CLOUDFRONT_URL="PASTE_FROM_CDK_OUTPUT"
S3_FRONTEND_BUCKET="PASTE_FROM_CDK_OUTPUT"

# --- IAM (from CDK outputs) ---
TASK_ROLE_NAME="PASTE_FROM_CDK_OUTPUT"

# --- CloudWatch Log Groups (from CDK outputs) ---
MARKET_DATA_LOG_GROUP="PASTE_FROM_CDK_OUTPUT"
ORDER_LOG_GROUP="PASTE_FROM_CDK_OUTPUT"

# --- DynamoDB ---
DYNAMODB_TABLE="market-data-ticks"

# --- DevOps Agent (from DevOps Agent console setup) ---
DEVOPS_AGENT_WEBHOOK_URL="PASTE_FROM_DEVOPS_AGENT_CONSOLE"
DEVOPS_AGENT_WEBHOOK_SECRET="PASTE_FROM_DEVOPS_AGENT_CONSOLE"

# --- GitHub ---
GITHUB_REPO="YOUR_GITHUB_USERNAME/trading-platform"
